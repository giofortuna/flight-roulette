{
  "name": "airways-roulette",
  "type": "module",
  "version": "1.0.0",
  "description": "Random flight generator for flight simulator pilots",
  "license": "MIT",
  "author": "Gio Fortuna",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "tsx --test",
    "dev": "serve .",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.giofortuna.flight-roulette",
    "productName": "Flight Roulette",
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "index.html",
      "css/**",
      "fonts/**",
      "dist/**",
      "data/*.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  },
  "private": true
}
